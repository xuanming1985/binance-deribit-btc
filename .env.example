# 环境变量模板 - 复制为 .env 并填入真实 Key
# 实际 .env 文件应加入 .gitignore, 绝不提交到代码仓库

# ============ Telegram 机器人 ============
TG_BOT_TOKEN=
TG_CHAT_ID=
# 可选: 限制哪些 Telegram user_id 可以发命令 (用逗号分隔, 留空则只验证 chat_id)
TG_ALLOWED_USER_IDS=

# ============ Deribit BTC 账户 ============
DERIBIT_BTC_CLIENT_ID=
DERIBIT_BTC_CLIENT_SECRET=

# ============ Deribit ETH 账户 ============
DERIBIT_ETH_CLIENT_ID=
DERIBIT_ETH_CLIENT_SECRET=

# ============ Binance 账户 ============
BINANCE_API_KEY=
BINANCE_API_SECRET=
